---
/**
 * ChatbotWidget.astro
 *
 * Drop-in Astro component for the Cyberfyx Compliance Evaluation Chatbot.
 * Place this component inside BaseLayout.astro just before </body>.
 *
 * Usage in BaseLayout.astro:
 *   import ChatbotWidget from '../components/ChatbotWidget.astro';
 *   <ChatbotWidget />
 */
---

<!-- Chatbot styles -->
<link rel="stylesheet" href="/chatbot.css" />

<!-- ─── Chat Widget Root ────────────────────────────────────────────────────── -->
<div id="cbot-widget" role="complementary" aria-label="Compliance Assessment Chatbot">

  <!-- FAB (Floating Action Button) -->
  <button
    id="cbot-fab"
    type="button"
    aria-label="Open ISO 27001 readiness assessment"
    aria-controls="cbot-panel"
    aria-expanded="false"
  >
    <span class="cbot-fab-icon">
      <i class="fa-solid fa-shield-halved"></i>
    </span>
    <span class="cbot-fab-label">Compliance Assessment</span>
    <span class="cbot-fab-badge" aria-hidden="true">16</span>
  </button>

  <!-- Chat Panel -->
  <div
    id="cbot-panel"
    role="dialog"
    aria-modal="false"
    aria-labelledby="cbot-panel-title"
    aria-describedby="cbot-progress-label"
    aria-hidden="true"
  >
    <!-- Panel Header -->
    <div class="cbot-header">
      <div class="cbot-header-avatar">
        <img src="/favicon.png" alt="Cyberfyx" width="24" height="24" />
      </div>
      <div class="cbot-header-info">
        <div class="cbot-header-name" id="cbot-panel-title">Cyberfyx Compliance Advisor</div>
        <div class="cbot-header-status">ISO 27001 Readiness Assessment</div>
      </div>
      <div class="cbot-header-actions">
        <button
          id="cbot-minimize"
          class="cbot-header-btn"
          type="button"
          aria-label="Minimise chat"
          title="Minimise"
        >
          <i class="fa-solid fa-minus"></i>
        </button>
        <button
          id="cbot-close"
          class="cbot-header-btn"
          type="button"
          aria-label="Close chat"
          title="Close"
        >
          <i class="fa-solid fa-xmark"></i>
        </button>
      </div>
    </div>

    <!-- Progress Bar -->
    <div class="cbot-progress-wrap">
      <div class="cbot-progress-track">
        <div id="cbot-progress-fill" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
      </div>
      <div id="cbot-progress-label">Compliance Evaluation</div>
    </div>

    <!-- Messages -->
    <div id="cbot-messages" role="log" aria-live="polite" aria-atomic="false">
      <!-- Messages are injected by chatbot.ts -->
    </div>

    <!-- Input Area -->
    <div id="cbot-input-area" role="group" aria-label="Chat input area">
      <!-- Dynamic input rendered by chatbot.ts -->
    </div>
  </div>

</div>

<!-- Chatbot script (module — deferred automatically by Astro) -->
<script>
  import '../scripts/chatbot.ts';
</script>
